# Resident Advisor API Configuration
# Copy this file to .env and fill in your actual values

# RA API Base URL (this is an example - get the actual URL from RA)
VITE_RA_API_URL=https://api.ra.co/v1

# Your RA API Key (obtain from RA after approval)
VITE_RA_API_KEY=your_api_key_here

# Use mock data for development (true/false)
# Set to false when you have a real API key
VITE_USE_MOCK_DATA=true

# Optional: Backend proxy URL if you need to bypass CORS
VITE_PROXY_URL=http://localhost:5000

# Optional: API request timeout in milliseconds
VITE_API_TIMEOUT=10000